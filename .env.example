# Copy to .env and fill in. Every key is optional — sources without keys are skipped.

# SEC EDGAR requires a User-Agent identifying you (no key needed)
EDGAR_USER_AGENT="stock-signals/0.1 (ishtiaq.fauzan@gmail.com)"

# Financial Modeling Prep — paid Starter tier planned (statements, estimates, EOD prices)
FMP_API_KEY=

# Twelve Data — free tier, 800 credits/day (fallback candles)
TWELVEDATA_API_KEY=

# Finnhub — free tier, 60 calls/min (quotes + company news)
FINNHUB_API_KEY=

# Tiingo — free tier, 30yr EOD history, 500 unique symbols/month (backtest history)
TIINGO_API_KEY=

# FRED — free (macro series)
FRED_API_KEY=

# Anthropic — Haiku batch sentiment (Phase 3)
ANTHROPIC_API_KEY=

# Reddit OAuth app, type "script" — optional; anonymous access works, creds raise the rate limit 10x
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Bluesky — free account; generate an app password at bsky.app Settings > Privacy and Security (post search requires login)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
